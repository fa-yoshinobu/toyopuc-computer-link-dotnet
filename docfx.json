{
  "metadata": [
    {
      "src": [
        {
          "files": ["src/**/*.csproj"],
          "exclude": ["**/bin/**", "**/obj/**"]
        }
      ],
      "dest": "obj/api"
    }
  ],
  "build": {
    "content": [
      {
        "files": ["obj/api/**.yml"],
        "dest": "api"
      },
      {
        "files": ["**/*.md", "**/toc.yml"],
        "exclude": ["**/maintainer/**", "**/validation/**", "**/internal_docs/**"],
        "src": "docsrc"
      },
      {
        "files": ["README.md", "toc.yml"],
        "exclude": ["**/maintainer/**", "**/validation/**", "**/internal_docs/**"]
      }
    ],
    "resource": [
      {
        "files": ["docsrc/user/assets/**"]
      }
    ],
    "dest": "docs",
    "globalMetadata": {
      "_disablePdf": true,
      "_appTitle": "TOYOPUC Computer Link .NET Documentation",
      "_enableSearch": true,
      "_enableNewTab": true,
      "_appFooter": "PLC Communication Workspace - fa-yoshinobu"
    },
    "template": [
      "default",
      "modern"
    ]
  }
}
